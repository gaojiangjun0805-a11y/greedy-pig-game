.page {
  min-height: 100vh;
  background: radial-gradient(ellipse at 20% 20%, #2d1b69 0%, #11072f 45%, #0a0a1a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 24rpx;
  position: relative;
}

.bg-canvas {
  position: fixed;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  pointer-events: none;
  z-index: 0;
}

.title-wrap {
  text-align: center;
  margin-bottom: 16rpx;
  z-index: 1;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  letter-spacing: 12rpx;
  background: linear-gradient(135deg, #ff9de2, #c084fc, #67e8f9);
  -webkit-background-clip: text;
  color: transparent;
}

.subtitle {
  display: block;
  font-size: 22rpx;
  color: #a78bfa;
  letter-spacing: 2rpx;
  margin-top: 4rpx;
}

/* 难度 */
.diff-bar {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 16rpx;
  z-index: 1;
}

.diff-btn {
  padding: 10rpx 32rpx;
  border-radius: 999rpx;
  border: 2rpx solid transparent;
  font-size: 26rpx;
  color: #c4b5fd;
  background: rgba(255,255,255,0.07);
}

.diff-btn.active { color: #fff; }
.d1 { border-color: #4ade80; background: rgba(74,222,128,0.2); }
.d2 { border-color: #facc15; background: rgba(250,204,21,0.2); }
.d3 { border-color: #f87171; background: rgba(248,113,113,0.2); }

/* HUD */
.hud {
  display: flex;
  flex-direction: row;
  gap: 32rpx;
  font-size: 28rpx;
  color: #c4b5fd;
  background: rgba(255,255,255,0.06);
  padding: 10rpx 36rpx;
  border-radius: 999rpx;
  margin-bottom: 16rpx;
  z-index: 1;
}

.hud-val { color: #fde68a; font-weight: bold; }

/* 棋盘 */
.board-wrap {
  position: relative;
  z-index: 1;
}

.line-canvas {
  position: absolute;
  top: 0; left: 0;
  pointer-events: none;
  z-index: 10;
}

.board {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 16rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 28rpx;
  border: 2rpx solid rgba(255,255,255,0.08);
  gap: 10rpx;
  box-sizing: border-box;
}

/* 格子 */
.cell {
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255,255,255,0.15);
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.4);
  transition: all 0.15s;
}

.cell.selected {
  border-color: #fde68a;
  box-shadow: 0 0 28rpx rgba(253,230,138,0.6);
  transform: scale(1.08);
}

.cell.hint-glow {
  border-color: #a78bfa;
  box-shadow: 0 0 32rpx rgba(167,139,250,0.8);
}

.cell.empty {
  background: transparent !important;
  border-color: transparent !important;
  box-shadow: none !important;
}

.num {
  font-size: inherit;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
}

.pf {
  font-size: 18rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 2rpx;
}

/* 按钮 */
.buttons {
  display: flex;
  flex-direction: row;
  gap: 14rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
  justify-content: center;
  z-index: 1;
}

.btn {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: bold;
  text-align: center;
}

.btn-new     { background: linear-gradient(135deg,#f87171,#e94560); color:#fff; }
.btn-undo    { background: linear-gradient(135deg,#64748b,#4b5563); color:#fff; }
.btn-hint    { background: linear-gradient(135deg,#fde68a,#f59e0b); color:#1a1a2e; }
.btn-shuffle { background: linear-gradient(135deg,#67e8f9,#38bdf8); color:#0a0a1a; }
.btn.disabled { opacity: 0.3; }

/* 消息 */
.msg {
  margin-top: 14rpx;
  min-height: 36rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #fde68a;
  letter-spacing: 2rpx;
  z-index: 1;
}

/* 图例 */
.legend {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 10rpx;
  z-index: 1;
}
.leg-item { display: flex; align-items: center; font-size: 22rpx; color: #6d5fa0; }
.ld { width: 14rpx; height: 14rpx; border-radius: 4rpx; margin-right: 6rpx; }

/* 支付弹窗 */
.pay-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.pay-modal {
  background: #1e1040;
  border: 2rpx solid #c084fc;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 0 60rpx rgba(192,132,252,0.3);
}

.pay-title { font-size: 44rpx; font-weight: bold; color: #fff; }
.pay-desc  { font-size: 28rpx; color: #a78bfa; text-align: center; }
.pay-price { font-size: 72rpx; font-weight: bold; color: #fde68a; }
.btn-pay   { background: linear-gradient(135deg,#c084fc,#a855f7); color:#fff; width:320rpx; margin-top:10rpx; }
.btn-cancel{ background: rgba(255,255,255,0.1); color:#94a3b8; width:320rpx; }

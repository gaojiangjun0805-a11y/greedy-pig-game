<!-- 公约数列 · 微信小程序 -->
<view class="page">

  <!-- 背景粒子 -->
  <canvas type="2d" id="bg-canvas" class="bg-canvas"></canvas>

  <!-- 标题 -->
  <view class="title-wrap">
    <text class="title">公 约 数 列</text>
    <text class="subtitle">连通两数 · 各除最大公约数 · 商为1则消除 ✨</text>
  </view>

  <!-- 难度选择 -->
  <view class="diff-bar">
    <view class="diff-btn {{diff==1?'active d1':''}}" bindtap="setDiff" data-d="1">🌱 初级</view>
    <view class="diff-btn {{diff==2?'active d2':''}}" bindtap="setDiff" data-d="2">🌙 中级</view>
    <view class="diff-btn {{diff==3?'active d3':''}}" bindtap="setDiff" data-d="3">🔥 高级</view>
  </view>

  <!-- HUD -->
  <view class="hud">
    <text>🧩 <text class="hud-val">{{remaining}}</text></text>
    <text>⏱ <text class="hud-val">{{timeLeft}}</text>s</text>
    <text>⭐ <text class="hud-val">{{score}}</text></text>
  </view>

  <!-- 棋盘 -->
  <view class="board-wrap">
    <canvas type="2d" id="line-canvas" class="line-canvas"
            style="width:{{boardPx}}px;height:{{boardPx}}px"></canvas>
    <view class="board" style="width:{{boardPx}}px">
      <block wx:for="{{cells}}" wx:key="index">
        <view
          class="cell {{item.empty?'empty':''}} {{item.selected?'selected':''}} {{item.hint?'hint-glow':''}}"
          style="width:{{cellPx}}px;height:{{cellPx}}px;background:{{item.bg}};border-color:{{item.border}};font-size:{{fontSize}}"
          bindtap="onCellTap"
          data-i="{{index}}"
        >
          <text wx:if="{{!item.empty}}" class="num">{{item.val}}</text>
          <text wx:if="{{!item.empty}}" class="pf">{{item.pf}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 按钮 -->
  <view class="buttons">
    <view class="btn btn-new"     bindtap="newGame">🎮 新游戏</view>
    <view class="btn btn-undo {{undoStack.length==0?'disabled':''}}" bindtap="doUndo">↩ 悔棋</view>
    <view class="btn btn-hint"    bindtap="showHint">💡 提示</view>
    <view class="btn btn-shuffle" bindtap="shuffleBoard">🔀 重排</view>
  </view>

  <!-- 消息 -->
  <view class="msg">{{msg}}</view>

  <!-- 图例 -->
  <view class="legend">
    <view class="leg-item"><view class="ld" style="background:#60a5fa"></view><text>含2</text></view>
    <view class="leg-item"><view class="ld" style="background:#4ade80"></view><text>含3</text></view>
    <view class="leg-item"><view class="ld" style="background:#fb923c"></view><text>含5</text></view>
    <view class="leg-item"><view class="ld" style="background:#c084fc"></view><text>含7</text></view>
  </view>

  <!-- 支付解锁弹窗（初级免费，中/高级付费）-->
  <view class="pay-mask" wx:if="{{showPayModal}}">
    <view class="pay-modal">
      <text class="pay-title">🔒 解锁高级关卡</text>
      <text class="pay-desc">中级和高级关卡需要一次性解锁</text>
      <view class="pay-price">¥ 6</view>
      <view class="btn btn-pay" bindtap="doPay">立即解锁</view>
      <view class="btn btn-cancel" bindtap="cancelPay">取消</view>
    </view>
  </view>

</view>
